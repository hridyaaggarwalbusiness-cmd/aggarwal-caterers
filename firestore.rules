rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /menus/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /siteSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /inquiries/{docId} {
      allow read, write: if request.auth != null;
      match /responses/{responseId} {
        allow read, write: if request.auth != null;
      }
    }
    match /orders/{docId} {
      allow read, write: if request.auth != null;
    }
    match /testimonials/{docId} {
      allow read: if true;
      allow create: if
        (request.resource.data.rating >= 4 && request.resource.data.status == 'Approved') ||
        (request.resource.data.rating < 4 && request.resource.data.status == 'Pending') ||
        (!('rating' in request.resource.data) && request.resource.data.status == 'Pending');
      allow update, delete: if request.auth != null;
    }
    match /gallery/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /faqs/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}